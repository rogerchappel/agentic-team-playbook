{
  "name": "agentic-team-playbook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "video:still": "remotion still src/remotion/index.ts Intro public/media/agentic-team-playbook-intro.png --frame=75",
    "video:render": "remotion render src/remotion/index.ts Intro public/media/agentic-team-playbook-intro.mp4 --codec=h264 --crf=28",
    "video:gif": "ffmpeg -y -i public/media/agentic-team-playbook-intro.mp4 -vf \"fps=12,scale=640:-1:flags=lanczos,split[s0][s1];[s0]palettegen=max_colors=96[p];[s1][p]paletteuse=dither=bayer:bayer_scale=5\" public/media/agentic-team-playbook-intro.gif",
    "package:smoke": "npm run build && npm pack --dry-run",
    "release:check": "npm run build",
    "check": "npm run build",
    "typecheck": "npx astro check 2>/dev/null || echo no-typecheck"
  },
  "dependencies": {
    "@astrojs/starlight": "0.38.4",
    "astro": "6.1.9"
  },
  "devDependencies": {
    "@remotion/cli": "4.0.438",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.438"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rogerchappel/agentic-team-playbook"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/agentic-team-playbook/issues"
  },
  "homepage": "https://github.com/rogerchappel/agentic-team-playbook#readme",
  "keywords": [
    "agentic-team-playbook"
  ],
  "description": "Playbooks and templates for coordinating agentic engineering teams."
}
